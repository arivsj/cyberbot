{
  "name": "cyberbot",
  "version": "1.0.0",
  "description": "Dashboard Cyberpunk para Telegram + Ollama",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.cyberbot.app",
    "productName": "CyberBot",
    "linux": {
      "target": ["deb", "AppImage"],
      "icon": "icon.png",
      "category": "Utility"
    },
    "extraResources": [
      {
        "from": "../bot.py",
        "to": "backend/bot.py"
      },
      {
        "from": "../db.py",
        "to": "backend/db.py"
      },
      {
        "from": "../server.py",
        "to": "backend/server.py"
      }
    ]
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.0.0"
  }
}
